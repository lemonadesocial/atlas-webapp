# Atlas Registry API (federated event search)
NEXT_PUBLIC_ATLAS_REGISTRY_URL=

# Lemonade Backend API (server-only: event detail, tickets, purchase)
LEMONADE_BACKEND_URL=

# Public URL of this app (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nominatim geocoding API (default: OpenStreetMap public instance)
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Lemonade main app URL (for dashboard/create-event links)
NEXT_PUBLIC_LEMONADE_APP_URL=https://app.lemonade.social

# OAuth (server-side only)
NEXT_PUBLIC_OAUTH_CLIENT_ID=atlas-webapp
NEXT_PUBLIC_OAUTH_AUTHORITY=
OAUTH_CLIENT_SECRET=

# Lemonade AI (server-side only, for chat proxy)
LEMONADE_AI_URL=

# Sentry error tracking (optional)
SENTRY_DSN=
