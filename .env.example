# Public URL of this app (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://localhost.staging.lemonade.social:3000

# Nominatim geocoding API
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Lemonade main app URL (for dashboard/create-event links)
NEXT_PUBLIC_LEMONADE_APP_URL=https://app.staging.lemonade.social

# Identity service (login/registration)
NEXT_PUBLIC_IDENTITY_URL=https://identity.staging.lemonade.social

# Kratos (logout)
NEXT_PUBLIC_KRATOS_PUBLIC_URL=https://kratos.staging.lemonade.social

# Lemonade AI (chat)
NEXT_PUBLIC_LEMONADE_AI_URL=

# Sentry error tracking (optional)
SENTRY_DSN=
