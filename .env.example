# Atlas Registry API (federated event search)
NEXT_PUBLIC_ATLAS_REGISTRY_URL=https://atlas-registry.staging.lemonade.social

# Lemonade Backend API
NEXT_PUBLIC_LEMONADE_BACKEND_URL=https://backend.staging.lemonade.social
LEMONADE_BACKEND_URL=https://backend.staging.lemonade.social

# Public URL of this app (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://localhost.staging.lemonade.social:8001

# Nominatim geocoding API
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Lemonade main app URL (for dashboard/create-event links)
NEXT_PUBLIC_LEMONADE_APP_URL=https://app.staging.lemonade.social

# Identity service (login/registration)
NEXT_PUBLIC_IDENTITY_URL=https://identity.staging.lemonade.social

# Kratos (logout)
NEXT_PUBLIC_KRATOS_PUBLIC_URL=https://kratos.staging.lemonade.social

# Lemonade AI (chat via GraphQL run mutation)
AI_API_HTTP=https://ai.staging.lemonade.social
NEXT_PUBLIC_AI_CONFIG=

# Sentry error tracking (optional)
SENTRY_DSN=
