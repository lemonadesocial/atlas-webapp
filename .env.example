# Atlas Registry API (federated event search)
NEXT_PUBLIC_ATLAS_REGISTRY_URL=

# Lemonade Backend API (event detail, tickets, purchase)
NEXT_PUBLIC_LEMONADE_BACKEND_URL=

# Public URL of this app (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nominatim geocoding API (default: OpenStreetMap public instance)
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Sentry error tracking (optional)
SENTRY_DSN=
